# Frontend environment.
# Only NEXT-PUBLIC-equivalent values belong here (Vite exposes VITE_* to the browser bundle).
# Anything secret stays out of the frontend per docs/conventions.md §9.

# In dev, the Vite proxy forwards /api/* to localhost:8000, so VITE_API_URL is usually unused.
# In prod, point this at the deployed API origin.
VITE_API_URL=
