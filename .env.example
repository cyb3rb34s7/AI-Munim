# AI-Munim environment.
# Copy this file to .env and fill in values. Per docs/conventions.md §9,
# required env vars have NO default in code, so the app will fail at startup
# if any are missing.

# --- Phase 1 (in code now) ---

# SQLite file path. The parent dir is auto-created at startup.
DATABASE_URL=sqlite:///./data/munim.sqlite

# debug | info | warning | error
LOG_LEVEL=info

# development | staging | production
APP_ENV=development

# --- Phase 4: Shopify real OAuth (required at startup) ---
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2026-04
# Backend serves this path directly — the /api prefix in the frontend is a
# Vite dev-proxy convention, not a backend route. Use plain /connectors/...
SHOPIFY_OAUTH_REDIRECT_URI=http://localhost:8000/connectors/shopify/oauth/callback
SHOPIFY_DEFAULT_SHOP_DOMAIN=your-store.myshopify.com

# AES-GCM key (URL-safe base64, decodes to 32 bytes). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CREDENTIALS_ENCRYPTION_KEY=

# Optional — base URL the OAuth callback redirects back to (default works for dev)
FRONTEND_BASE_URL=http://localhost:5173

# --- Phase 5: OpenAI chat ---
# Required. Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Default: gpt-4o-mini (cheap + tool-use capable). Override to gpt-4o for harder questions.
OPENAI_CHAT_MODEL=gpt-4o-mini
# 0.0 keeps grounded answers deterministic-ish. Set higher only for casual chat.
OPENAI_CHAT_TEMPERATURE=0.0
# Optional — used by Phase 6+ if we add embedding-based search.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
